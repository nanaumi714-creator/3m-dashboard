# Environment Variables Example
# Copy this to appropriate locations and fill in actual values from `npx supabase start`

# Frontend (web/.env.local)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_***
SUPABASE_SERVICE_ROLE_KEY=sb_secret_***

# Importer (importer/.env)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=sb_secret_***

# Optional: Direct DB connection
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Optional: S3-compatible Storage (Phase 1 late/Phase 2)
SUPABASE_S3_ENDPOINT=http://127.0.0.1:54321/storage/v1/s3
SUPABASE_S3_REGION=local
SUPABASE_S3_ACCESS_KEY=***
SUPABASE_S3_SECRET_KEY=***