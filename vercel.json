{
    "buildCommand": "cd web && npm run build",
    "outputDirectory": "web/.next",
    "devCommand": "cd web && npm run dev",
    "installCommand": "cd web && npm install",
    "framework": "nextjs",
    "regions": [
        "hnd1"
    ],
    "crons": [
        {
            "path": "/api/cron/gmail-sync",
            "schedule": "0 9 * * *"
        },
        {
            "path": "/api/cron/backup",
            "schedule": "0 2 * * *"
        }
    ]
}
